{
    "manifest_version": 3,
    "name": "Browser Pipe",
    "version": "0.1.0",
    "description": "Forward fetch requests from MCP server with browser cookies",
    "permissions": [
        "alarms",
        "offscreen",
        "scripting"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "128": "icons/icon.png"
    }
}
